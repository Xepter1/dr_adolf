{
  "name": "draft-website",
  "version": "1.0.0",
  "description": "Wiederverwendbarer Website-Draft (Next.js + Payload CMS + SQLite)",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "reset": "node scripts/reset.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
