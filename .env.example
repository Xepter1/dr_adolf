# Pflicht: langer, zufälliger Wert. Pro Deployment EINMALIG neu erzeugen
# (z. B. `openssl rand -hex 32`). Niemals zwischen Projekten wiederverwenden.
PAYLOAD_SECRET=

# Anzeigename des Projekts (Admin-Panel-Titel & Fallback für den Mail-Absendernamen).
SITE_NAME=Draft Website

# SQLite-Datei. Lokal relativ, im Docker-Container auf einem Volume.
DATABASE_URI=file:./content.db

# Öffentliche URL der Seite (für Admin-Login hinter Domain/Proxy & Metadaten).
# Lokal leer lassen – dann läuft alles über localhost:3000.
PUBLIC_URL=

# Demo-/Vorschaubetrieb: "true" → die Seite wird per <meta robots noindex> komplett
# aus dem Google-Index gehalten. Auf der echten Live-Domain leer lassen/"false".
DEMO_MODE=

# Nur fürs Deploy (compose.hetzner.yml): Domain, die Caddy bedient (HTTPS automatisch).
# Wird im Portainer-Stack gesetzt, nicht lokal nötig.
DOMAIN=

# Speicherort der Medien-Uploads.
MEDIA_DIR=media

# E-Mail-Versand (Kontaktformular-Benachrichtigungen, Passwort-Reset).
# Ohne diese Werte werden Mails nur in die Konsole geloggt (Dev-Modus).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=

# Empfänger der Kontaktformular-Anfragen (sonst greift der Fallback im Seed).
CONTACT_TO=

# Geheimnis für den Wartungs-Endpunkt /cron (Erinnerungen, Aufräumen, Löschfristen).
# Langer Zufallswert (openssl rand -hex 32). Regelmäßig aufrufen:
#   curl "https://<domain>/cron?secret=$CRON_SECRET"   (z. B. stündlich per Cron)
CRON_SECRET=

# Admin-Erstbenutzer beim allerersten Start (nur wenn noch kein Benutzer existiert).
ADMIN_EMAIL=
ADMIN_PASSWORD=
